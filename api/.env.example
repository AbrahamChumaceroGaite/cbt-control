# ── Base de datos ──────────────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"        # SQLite (dev)
# DATABASE_URL="file:/app/data/prod.db"   # SQLite en Docker

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET="cbt-control-aula-jwt-secret-change-in-prod"

# ── Servidor ───────────────────────────────────────────────────────────────────
PORT=4001
WEB_ORIGIN=http://localhost:3001           # URL pública del frontend (CORS + WS)

# ── Web Push (VAPID) ───────────────────────────────────────────────────────────
# Generar claves: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com
