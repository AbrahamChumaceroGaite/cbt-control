generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

// LOCAL DEV: provider = "sqlite", DATABASE_URL = "file:./dev.db"
// VERCEL:    provider = "postgresql", DATABASE_URL = "postgresql://...", DIRECT_URL = "postgresql://..."
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Course {
  id          String   @id @default(cuid())
  name        String   // "S2A"
  level       String   // "Secondary 1" | "Secondary 2"
  parallel    String   // "A" | "B" | "C"
  classCoins  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  students    Student[]
  coinLogs    CoinLog[]
  redemptions Redemption[]
  groups      Group[]
}

model Student {
  id        String   @id @default(cuid())
  courseId  String
  code      String   @default("")
  name      String
  email     String?
  coins     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course               Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  coinLogs             CoinLog[]
  tramos               StudentTramo[]
  individualRedemptions StudentRedemption[]
  groupMemberships     GroupMember[]
  user                 User?
  redemptionRequests   RedemptionRequest[]
}

model StudentTramo {
  id        String   @id @default(cuid())
  studentId String
  tramo     String
  awardedAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, tramo])
}

model Reward {
  id             String   @id @default(cuid())
  name           String
  description    String   @default("")
  icon           String   @default("★")
  coinsRequired  Int
  type           String   @default("class") // "class" | "individual"
  isGlobal       Boolean  @default(true)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  redemptions           Redemption[]
  individualRedemptions StudentRedemption[]
  redemptionRequests    RedemptionRequest[]
}

model Redemption {
  id         String   @id @default(cuid())
  courseId   String
  rewardId   String
  notes      String   @default("")
  redeemedAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  reward Reward @relation(fields: [rewardId], references: [id])
}

model StudentRedemption {
  id         String   @id @default(cuid())
  studentId  String
  rewardId   String
  redeemedAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reward  Reward  @relation(fields: [rewardId], references: [id])
}

model Action {
  id             String   @id @default(cuid())
  name           String
  coins          Int
  category       String   @default("blue") // "green"|"blue"|"red"|"amber"|"purple"|"mag"
  affectsClass   Boolean  @default(true)
  affectsStudent Boolean  @default(true)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  coinLogs CoinLog[]
}

model CoinLog {
  id        String   @id @default(cuid())
  courseId  String
  studentId String?
  actionId  String?
  coins     Int
  reason    String
  createdAt DateTime @default(now())

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  action  Action?  @relation(fields: [actionId], references: [id], onDelete: SetNull)
}

model Group {
  id        String   @id @default(cuid())
  name      String
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course   Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  members  GroupMember[]
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  studentId String
  joinedAt  DateTime @default(now())

  group   Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([groupId, studentId])
}

// ── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  code         String   @unique   // login username: "admin" | "s1a01" | "s2b12"
  passwordHash String
  role         String   @default("student") // "admin" | "student"
  studentId    String?  @unique
  fullName     String   @default("")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)
}

model RedemptionRequest {
  id        String   @id @default(cuid())
  studentId String
  rewardId  String
  status    String   @default("pending") // "pending" | "approved" | "rejected"
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reward  Reward  @relation(fields: [rewardId], references: [id])
}
