# ── Docker / Producción ────────────────────────────────────────────────────────
# Este archivo es leído por docker-compose.yml a través de env_file: ./api/.env
# Copia en api/.env con los valores reales

DATABASE_URL="file:/app/data/prod.db"
JWT_SECRET="change-in-production"

# Web Push (VAPID) — generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com

# Puerto expuesto al host (cloud proxy apunta aquí)
WEB_PORT=3001
