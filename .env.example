# ── Base de datos ─────────────────────────────────────────────────────────────
# Para desarrollo local con Docker:
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cbt_control_aula"
#   DIRECT_URL="postgresql://postgres:postgres@localhost:5432/cbt_control_aula"
#
# Para Vercel + Supabase / Neon / Vercel Postgres:
#   DATABASE_URL="postgresql://user:pass@host:5432/dbname?pgbouncer=true&connection_limit=1"
#   DIRECT_URL="postgresql://user:pass@host:5432/dbname"
#
# DIRECT_URL es necesario cuando DATABASE_URL usa un pooler (pgbouncer).
# Si no usas pooler, ambas variables pueden ser idénticas.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cbt_control_aula"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/cbt_control_aula"

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET="cbt-control-aula-jwt-secret-2026-change-in-prod"
