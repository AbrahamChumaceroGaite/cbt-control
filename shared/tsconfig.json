{
  "compilerOptions": {
    "target":            "ES2021",
    "module":            "commonjs",
    "declaration":       true,
    "emitDeclarationOnly": false,
    "outDir":            "./dist",
    "rootDir":           "./src",
    "strict":            true,
    "skipLibCheck":      true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
